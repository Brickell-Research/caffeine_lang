Blueprints
  "api_availability":
    Requiring { env: String, service: String, vendor: String, evaluation: String, indicators: Dict(String, String), threshold: Float, window_in_days: Integer { x | x in ( 1..90 ) } }
    Provides {
      vendor: "datadog",
      evaluation: "numerator / denominator",
      indicators: {
        numerator: "sum:http.requests{$env->env$,$service->service$,!status:5xx}",
        denominator: "sum:http.requests{$env->env$,$service->service$}"
      }
    }
  "api_latency_p99":
    Requiring { env: String { x | x in { "staging", "production" } }, service: String, vendor: String, evaluation: String, indicators: Dict(String, String), threshold: Float, window_in_days: Integer { x | x in ( 1..90 ) } }
    Provides {
      vendor: "datadog",
      evaluation: "numerator / denominator",
      indicators: {
        numerator: "sum:http.latency.p99{$env->env$,$service->service$,le:500}",
        denominator: "sum:http.latency.p99{$env->env$,$service->service$}"
      }
    }
