_base_slo (Requiring): { vendor: String }

Blueprints
  ## API Availability
  "api_availability" success_rate(numerator / denominator) extends [_base_slo]:
    Requiring {
      env: String,
      status: Boolean,
      threshold: Float { x | x in ( 0.0 .. 100.0 ) },
      window_in_days: Integer
    }
    signals {
      numerator: "sum:http.requests{$env->env$, $status->status.not$}",
      denominator: "sum:http.requests{$env->env$}"
    }
