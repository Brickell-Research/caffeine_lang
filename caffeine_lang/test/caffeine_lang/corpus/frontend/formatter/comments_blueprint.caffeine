## SLO Blueprints
# This file defines SLO blueprints
Blueprints
  # The main API availability SLO
  "api_availability":
    Requiring { env: String }
    Provides { vendor: "datadog" }

  ## Latency section
  # Latency tracking
  "api_latency":
    Requiring { env: String }
    Provides { vendor: "datadog" }
