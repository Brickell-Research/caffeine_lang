## Availability
# SLO blueprints for availability
Blueprints
  # API SLO
  "api":
    Requiring { env: String }
    Provides { vendor: "datadog" }

  ## Database SLOs
  # DB availability
  "db":
    Requiring { env: String }
    Provides { vendor: "datadog" }

## Latency
# SLO blueprints for latency
Blueprints
  "api_latency":
    Requiring { env: String }
    Provides { vendor: "datadog" }

## Throughput
Blueprints
  "api_throughput":
    Requiring { env: String }
    Provides { vendor: "datadog" }
