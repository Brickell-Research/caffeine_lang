# Type alias section
_env (Type): String { x | x in { "prod", "staging" } }

# Extendable section
## Base config
_base (Requiring): { vendor: String }

## First blueprint section
Blueprints
  # API SLO
  "api" success_rate(test) extends [_base]:
    Requiring { env: _env }
    signals { threshold: 99.9 }

## Second blueprint section
Blueprints
  "api_latency" success_rate(test) extends [_base]:
    Requiring { env: _env }
    signals { threshold_ms: 500 }
