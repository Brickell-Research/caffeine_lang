"checkout_availability":
  Guarantees 99.95% over 30d window as measured by "api_availability" with: {
    env: "production",
    service: "checkout-api"
  }

"checkout_latency_p99":
  Guarantees 99.0% over 7d window as measured by "api_latency_p99" with: {
    env: "production",
    service: "checkout-api"
  }
