_defaults (Provides): { env: "production", window_in_days: 30 }

"checkout_availability" extends [_defaults]:
  Guarantees 99.95% over 30d window as measured by "api_availability" with: {
    status: true
  }

"payment_availability" extends [_defaults]:
  Guarantees 99.99% over 30d window as measured by "api_availability" with: {
    status: true
  }
