_defaults (Provides): { env: "production" }
_strict (Provides): { extra: "x" }

"checkout" extends [_defaults]:
  Guarantees 99.95% over 30d window as measured by "api_availability" with: {
    status: true
  }

"payment" extends [_defaults, _strict]:
  Guarantees 99.95% over 30d window as measured by "api_availability" with: {
    status: true
  }
